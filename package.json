{
  "name": "stray-rescue-mvp",
  "version": "0.1.0",
  "private": true,
  "description": "Transparent rescue ledger mini program MVP built with Taro and React.",
  "scripts": {
    "dev:weapp": "taro build --type weapp --watch",
    "build:weapp": "taro build --type weapp",
    "format": "prettier --write \"src/**/*.{ts,tsx,scss,css,json}\" \"cloudfunctions/rescueApi/**/*.{js,json}\" \"scripts/**/*.mjs\" \"docs/**/*.json\" \"qa/**/*.json\" \"config/**/*.ts\" \"types/**/*.ts\" \"*.{js,json}\" README.md AGENTS.md",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,scss,css,json}\" \"cloudfunctions/rescueApi/**/*.{js,json}\" \"scripts/**/*.mjs\" \"docs/**/*.json\" \"qa/**/*.json\" \"config/**/*.ts\" \"types/**/*.ts\" \"*.{js,json}\" README.md AGENTS.md",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"config/**/*.ts\" \"types/**/*.ts\" \"scripts/**/*.mjs\" \"cloudfunctions/rescueApi/{index,mockSeed}.js\" \"cloudfunctions/rescueApi/src/**/*.js\" \"*.config.js\" --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test:ui": "rm -rf .tmp/ui-tests && tsc -p tsconfig.ui-tests.json && node --experimental-specifier-resolution=node --test .tmp/ui-tests/src/pages/rescue/detail/*.test.js .tmp/ui-tests/src/pages/rescue/expense/*.test.js .tmp/ui-tests/src/pages/rescue/record-detail/*.test.js .tmp/ui-tests/src/components/ui/*.test.js",
    "test:domain": "rm -rf .tmp/domain-tests && tsc -p tsconfig.domain-tests.json && node --experimental-specifier-resolution=node --test .tmp/domain-tests/src/domain/canonical/selectors/*.test.js .tmp/domain-tests/src/domain/canonical/repository/*.test.js",
    "report:style-tokens": "node scripts/report-style-tokens.mjs",
    "seed:alpha": "node scripts/seed-alpha-cloudbase.mjs",
    "check:repo-safety": "node scripts/check-sensitive-config.mjs",
    "preflight:alpha": "node scripts/run-alpha-preflight.mjs",
    "preflight:alpha:seed": "node scripts/run-alpha-preflight.mjs --seed-alpha"
  },
  "dependencies": {
    "@tarojs/components": "4.1.11",
    "@tarojs/helper": "4.1.11",
    "@tarojs/plugin-framework-react": "4.1.11",
    "@tarojs/plugin-platform-weapp": "4.1.11",
    "@tarojs/react": "4.1.11",
    "@tarojs/runtime": "4.1.11",
    "@tarojs/shared": "4.1.11",
    "@tarojs/taro": "4.1.11",
    "lucide-react": "0.577.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@babel/preset-react": "7.26.3",
    "@eslint/js": "^8.57.1",
    "@resvg/resvg-js": "^2.6.2",
    "@tarojs/cli": "4.1.11",
    "@tarojs/webpack5-runner": "4.1.11",
    "@types/node": "22.13.10",
    "@types/react": "18.3.18",
    "babel-preset-taro": "4.1.11",
    "eslint": "^8.57.1",
    "globals": "^16.5.0",
    "prettier": "^3.6.2",
    "sass": "1.85.1",
    "typescript": "5.8.2",
    "typescript-eslint": "^8.48.0"
  }
}
